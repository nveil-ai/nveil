# ==============================================================================
# Nveil Community Edition — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# Or run the setup wizard: docker compose run --rm --build setup
# ==============================================================================

# --- Database -----------------------------------------------------------------
POSTGRES_USER=nveil
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=nveil
DATABASE_SCHEMA=nveilseption

# AI state database password (for the ai_user in postgres)
AI_DB_PASSWORD=CHANGE_ME

# --- Security -----------------------------------------------------------------
# JWT signing key (64+ hex chars). The setup wizard generates one automatically.
SECRET_KEY=CHANGE_ME
# JWT algorithm (HS256 or HS512)
ALGORITHM=HS512

# Fernet key (urlsafe-base64 of 32 random bytes). Encrypts user-provided
# LLM API keys at rest. Generate with:
#   python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
APP_ENCRYPTION_KEY=CHANGE_ME

# --- LLM providers (BYOK) ----------------------------------------------------
# At least one must be set (commercial key or local endpoint+model).
# Boot order: Google → OpenAI → Anthropic → Mistral → Ollama → llama.cpp.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_MODEL=
LLAMACPP_BASE_URL=
LLAMACPP_MODEL=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# --- General ------------------------------------------------------------------
# Data storage: Docker volume name or absolute path
DIVE_DATA_PATH=nveil-dive-data

# --- Langfuse (optional: LLM tracing + prompt management) --------------------
# Set to 1 to enable. Start the tracing stack with:
#   docker compose --profile tracing up -d
# UI at http://localhost:3030 (login dev@nveil.com / dev-password)
LANGFUSE_TRACING=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Langfuse infrastructure (defaults work out of the box) -------------------
# Only change these if you need custom credentials for the tracing stack.
# LANGFUSE_DB_USER=langfuse
# LANGFUSE_DB_PASSWORD=langfuse
# LANGFUSE_CLICKHOUSE_USER=clickhouse
# LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse
# LANGFUSE_REDIS_PASSWORD=myredissecret
# LANGFUSE_MINIO_USER=minio
# LANGFUSE_MINIO_PASSWORD=miniosecret
# LANGFUSE_SALT=mysalt
# LANGFUSE_ENCRYPTION_KEY=a1b2c3d4e5f60718293a4b5c6d7e8f9012345678901234567890abcdef123456
# LANGFUSE_NEXTAUTH_SECRET=mysecret
# LANGFUSE_INIT_USER_PASSWORD=dev-password
