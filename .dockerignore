# Exclude everything by default
*

# Include only what the Dockerfiles actually COPY from the build context.
# choregraph + dive are NOT here: they left the monorepo and are pip-installed
# from PyPI (see docker/ai/requirements.txt), so no source is copied.
!nveil/backend/
!nveil/frontend/
!docker/
!connectors/
!examples/Miscellaneous/AirbnbGuest/

# Exclude heavy/problematic files within the included paths
nveil/frontend/node_modules/
nveil/frontend/dist/
**/__pycache__/
**/*.pyc
**/*.so
**/*.pem
