# syntax=docker/dockerfile:1

# ── Base ────────────────────────────────────────────────────────────────────
FROM python:3.12.13-slim-trixie AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 openssl ca-certificates curl libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY ./nveil/backend/tools/logger/ /nveil/backend/tools/logger/

RUN mkdir -p /root/DIVE/

RUN python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel \
    && /opt/venv/bin/pip install --no-cache-dir ruamel.yaml

ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
# Runtime defaults baked into the image (formerly the docker-compose
# x-backend-env anchor + mode flags). A container/compose/K8s env var still
# overrides any of these.
ENV PYTHONWARNINGS="ignore:::requests"
ENV KEDRO_LOGGING_CONFIG="/nveil/backend/tools/logger/logging_config.yaml"
ENV WATCHFILES_FORCE_POLLING="true"
ENV PYTHONPATH="/nveil/backend:/nveil/backend/tools/logger"
ENV ENV="local"
ENV LOCAL="1"
ENV GCP="0"

# ── AI Service ──────────────────────────────────────────────────────────────
FROM base

WORKDIR /nveil/backend/ai_service

# --- Stable deps ---

ARG REQUIREMENTS=requirements.txt
COPY ./docker/ai/${REQUIREMENTS} /tmp/requirements.txt
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r /tmp/requirements.txt

# --- Volatile local packages (small layers, re-pushed often) ---

COPY ./nveil/backend/tools/ /tmp/tools/
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install /tmp/tools/

# --- Entrypoint + application code (smallest, most volatile) ---

COPY ./docker/ai/entrypoint.sh /entrypoint.sh

COPY ./nveil/backend/ai_service/ /nveil/backend/ai_service/
COPY ./nveil/backend/shared/ /nveil/backend/shared/

# Service-discovery defaults (formerly docker-compose env); overridable.
ENV SERVER_HOST="server"
ENV SERVER_PORT="8000"
ENV STATE_DATABASE_SCHEMA="state_schema"

ENTRYPOINT ["sh", "/entrypoint.sh"]
