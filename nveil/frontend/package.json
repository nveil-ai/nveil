{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run fetch-vendor && vite build",
    "fetch-vendor": "node scripts/fetch-vendor-cdn.mjs",
    "fetch-vendor:clean": "node -e \"import('fs').then(fs => fs.rmSync('public/vendor', { recursive: true, force: true }))\" && npm run fetch-vendor",
    "lint": "eslint .",
    "preview": "vite preview",
    "prerender": "node prerender.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "perf": "playwright test --config=tests/perf/playwright.config.js",
    "perf:headed": "node tests/perf/scripts/run-with-env.mjs HEADED=1 playwright test --config=tests/perf/playwright.config.js",
    "perf:ui": "playwright test --config=tests/perf/playwright.config.js --ui",
    "perf:landing": "playwright test --config=tests/perf/playwright.config.js tier1-public",
    "perf:auth": "playwright test --config=tests/perf/playwright.config.js tier2-authenticated",
    "perf:static": "node tests/perf/static-checks/bundle-budget.mjs && node tests/perf/static-checks/import-graph.mjs && node tests/perf/static-checks/importmap.mjs",
    "perf:compare": "node tests/perf/scripts/compare-runs.mjs",
    "perf:baseline": "node tests/perf/scripts/compare-runs.mjs --update",
    "perf:codegen": "playwright codegen --ignore-https-errors https://localhost:8000"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@kitware/trame-react": "^1.2.1",
    "@kitware/vtk.js": "^35.10.1",
    "@react-oauth/google": "^0.13.5",
    "country-list": "^2.4.1",
    "deep-chat-react": "^2.4.2",
    "fast-xml-parser": "^5.7.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-yaml": "^4.1.1",
    "plotly.js-dist-min": "^3.5.0",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-cookie": "^8.1.0",
    "react-dom": "^19.2.5",
    "react-force-graph-2d": "^1.29.1",
    "react-grid-layout": "^2.2.3",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.6.0",
    "react-plotly.js": "^2.6.0",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^7.14.2",
    "react-select": "^5.10.2",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "puppeteer": "^24.35.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "subset-font": "^2.5.0",
    "vite": "8.0.10",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.5",
    "web-vitals": "^5.2.0"
  },
  "overrides": {
    "@kitware/trame-react": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
