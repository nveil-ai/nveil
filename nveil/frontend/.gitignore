# Self-hosted viz libs bundled from node_modules at build time.
# Generated by scripts/fetch-vendor-cdn.mjs (runs automatically before
# vite build). Reproducible from package.json; tracking ~10 MB of
# minified JS in git history provides no value.
public/vendor/

# Perf-test artifacts: auth state (contains session cookies) + per-run
# JSON results. Baseline and compare script ARE committed — just not
# the noisy run artifacts.
tests/perf/.auth/
tests/perf/results/

